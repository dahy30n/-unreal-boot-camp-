#include <stdio.h>
#include <stdbool.h>
#include <stdlib.h>

double solution(int numbers[], size_t numbers_len) {
    int sum = 0;
    
    for (size_t j = 0; j < numbers_len; j++) {
        sum += numbers[j];
    }
    
    return (double)sum / numbers_len;
}

int main() {
    int *v = NULL;
    int i;
    size_t size = 0;
    
    while (scanf("%d", &i)==true) {
        v= realloc(v, (size+1)*sizeof(int));
        v[size] += i;
        size++;
    }
        
    printf("%f", solution(v, size));
}
