#include <stdio.h>
#include <stdbool.h>
#include <stdlib.h>

int solution(int num) {
    int answer = 0;
    long long n = num;
    if (n==1) return answer;
    while (n != 1) {
        if (answer >=500) return -1;
        if (n%2 == 0 ) n = n/2;
        else if (n%2 != 0) n = n*3 + 1;
        answer++;
    }
    return answer;
}

int main() {
    int a = 0;
    scanf("%d",&a);
    solution(a);
}
