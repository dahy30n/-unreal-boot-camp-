#include <stdio.h>
#include <stdbool.h>
#include <stdlib.h>

long long solution(int a, int b) {
    long long answer = 0;
    if (a > b) {
    int t = a;
    a = b;
    b = t;
}
    
    for(int i=0; i<b-a+1; i++){
        answer += a+i;
    }    
    return answer;
}

int main(){
    int c=0,d=0; 
    scanf("%d %d",&c,&d);

    solution(c,d);
}
