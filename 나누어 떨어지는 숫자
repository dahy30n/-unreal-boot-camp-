#include <string>
#include <vector>
#include <iostream>
#include <algorithm>
using namespace std;

vector<int> solution(vector<int> arr, int divisor) {
    vector<int> answer;
    int a = 0;
    for (int i=0; i<arr.size(); i++) {
        if (arr[i]%divisor == 0) {
            a++;
            answer.push_back(arr[i]);
            
        }
    }
    sort(answer.begin(), answer.end());
    
    if (a==0) answer.push_back(-1);
    return answer;
}

int main() {
    vector<int> v;
    int x,y;
    while (cin >> x) {
        v.push_back(x);
    }
    cin >> y;
    solution(v,y);
}
