#include <stdio.h>
#include <stdbool.h>
#include <stdlib.h>

int solution(int n) {
    int arr[n], j=0, answer = 0;
    for(int i=1; i<=n; i++) {
        if (n%i==0) {
            arr[j] = i;
            j++;
        } 
    }
    
    for (int k=0; k<j;k++)
    {
        answer += arr[k];
    }
    return answer;
}

int main() {
    int a=0;
    scanf("%d",&a);
    printf("%d",solution(a));
}
