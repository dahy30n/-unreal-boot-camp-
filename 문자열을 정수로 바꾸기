#include <stdio.h>
#include <stdbool.h>
#include <stdlib.h>

// 파라미터로 주어지는 문자열은 const로 주어집니다. 변경하려면 문자열을 복사해서 사용하세요.
int solution(const char* s) {
    int answer = (int)strtol(s, NULL, 10) ;
    return answer;
}

int main()
{
    int n = 8, c = 0;
    char ch;
    char *arr = malloc(sizeof(strlen(ch))*sizeof(char));
    
    ch = getchar();
    while((ch=getchar())!="\n" && ch != EOF) {
        arr[c++] = (char)ch;
    }
    
    solution(arr);
    
    
}
