#include <stdio.h>
#include <stdbool.h>
#include <stdlib.h>
#include <math.h>



long long solution(long long n) {
    int answer = 0;
    
    if (n < 0) return -1;
    long long r = (long long)sqrt((long double)n);
    if (r * r == n ) {return (r+1)*(r+1);}
    else if ((r*r)!= n) {return -1;}
    
}

int main()
{
    long long a = 0;
    scanf("%lld",&a);
    solution(a);
}
