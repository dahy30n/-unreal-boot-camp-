#include <stdio.h>
#include <stdbool.h>
#include <stdlib.h>

int f(int n) {
    if (n % 2 == 0) return n;
    else return n - 1;
}

int solution(int a) {
    int n = f(a);
    int m = n / 2;
    return m * (m + 1);
}

int main() {
    int a;
    scanf("%d", &a);
    printf("%d", solution(a));
    return 0;
}
